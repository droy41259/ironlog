# ─────────────────────────────────────────────────────────────────────
# Firebase web client config (PUBLIC by design — these go in the browser bundle)
# Get them from: Firebase Console → Project Settings → Your apps → SDK setup
# ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional: scoping app for multi-tenant artifacts collection layout
NEXT_PUBLIC_APP_ID=ironlog

# Native (Capacitor) builds only: absolute origin of the hosted /api/gemini
# proxy, e.g. https://ironlog.example.com. Leave EMPTY for web builds (the app
# then calls the same origin). Inlined at build time, so set it before
# `npm run build:native`. The AI Coach is the only feature that needs this.
NEXT_PUBLIC_API_BASE_URL=

# ─────────────────────────────────────────────────────────────────────
# Server-only secrets — these MUST NOT have NEXT_PUBLIC_ prefix
# ─────────────────────────────────────────────────────────────────────
# Gemini API key (Google AI Studio)
GEMINI_API_KEY=

# Firebase Admin SDK service account, base64-encoded JSON
# Generate: Firebase Console → Project Settings → Service accounts → Generate new private key
# Then: cat serviceAccount.json | base64 | pbcopy
FIREBASE_SERVICE_ACCOUNT_B64=

# Optional: comma-separated allowed origins for CORS. Defaults to same-origin only.
ALLOWED_ORIGINS=
